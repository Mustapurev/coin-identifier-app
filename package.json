{
  "name": "coin-identifier-app",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Coin Identifier PWA – Multi-network ad mediation with Cloudflare Workers",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "worker:dev": "wrangler dev --config workers/wrangler.toml",
    "worker:deploy": "wrangler deploy --config workers/wrangler.toml",
    "deploy": "npm run build && npm run worker:deploy && npx wrangler pages deploy dist --project-name coin-identifier-app"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.3",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.20.5",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "wrangler": "^3.114.17"
  },
  "dependencies": {
    "@react-oauth/google": "^0.12.2",
    "@supabase/supabase-js": "^2.110.1",
    "dexie": "^4.4.4",
    "idb": "^8.0.3",
    "jwt-decode": "^4.0.0",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "zustand": "^5.0.14"
  }
}
